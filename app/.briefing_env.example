# Copy this file to ".briefing_env" (same folder) and fill in your values.
# deliver.py reads it for emailing. Keep the real .briefing_env private — it holds
# a password. (It is read only by you; do not commit it anywhere public.)

BRIEFING_GMAIL_USER=you@gmail.com

# A Gmail *App Password* (16 chars, NOT your normal login password). How to make one:
#   1. Turn on 2-Step Verification: https://myaccount.google.com/signinoptions/two-step-verification
#   2. Create an app password:       https://myaccount.google.com/apppasswords
#      Name it "paper briefing"; Google shows a 16-character code once.
#   3. Paste it below WITHOUT spaces.
BRIEFING_GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where the morning email goes (defaults to BRIEFING_GMAIL_USER if omitted).
BRIEFING_EMAIL_TO=you@example.edu
