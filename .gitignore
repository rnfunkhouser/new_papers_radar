# === secrets — NEVER commit ===
app/llm_api.json
app/.briefing_env
app/zotero.json
app/.deploy_env
*.key

# === your personal files (the .example templates ARE committed) ===
app/seeds.txt
app/interest_profile.json

# === large embedding caches (rebuildable; some >25MB) ===
# NOTE: keep comments on their OWN line — git treats an inline '#' as part of the pattern.
app/*_embeddings.json

# === derived profile artifacts (regenerate with: harvest.py --build-profile) ===
app/seeds_profile.json
app/seed_titles.json
app/clusters.json
app/interests.json

# === mutable runtime ledgers / state ===
app/judge_cache.json
app/alerts.json
app/proposals.json
app/seen.json
app/watchlist.json
app/feedback.json
app/topic_weights.json
app/venue_stats.json
app/zotero_imported.json
app/candidates.json

# === daily outputs & runtime dirs ===
app/briefings/
app/fulltext/
app/logs/
app/cards_*.json
app/data_*.json

# === diagnostics scratch ===
app/diagnose_*.json
app/experiment_caches/

# === tooling / python ===
.claude/
__pycache__/
*.pyc
.venv/
venv/
.DS_Store

# NOTE: app/config.toml IS committed — it holds your (non-secret) settings and the
# working defaults new users start from. Edit it in place to tune the radar.
