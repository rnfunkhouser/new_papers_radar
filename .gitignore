candidates.json

# === daily outputs & runtime dirs ===
briefings/
fulltext/
logs/
cards_*.json
data_*.json

# === diagnostics scratch ===
diagnose_*.json

# === tooling / python ===
.claude/
__pycache__/
*.pyc
.venv/
venv/

# NOTE: config.toml IS committed — it holds your (non-secret) settings and the
